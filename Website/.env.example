# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (get this from Vercel Postgres or neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=replace-with-a-long-random-string
FLASK_PORT=5000
FLASK_ENV=production

# ── Email Notifications (Gmail) ────────────────────────────────────────────────
# The Gmail address that sends notification emails
GMAIL_ADDRESS=your-gmail@gmail.com
# App Password (not your account password) — generate at:
# https://myaccount.google.com/apppasswords  (requires 2FA enabled)
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Where to send notifications (defaults to GMAIL_ADDRESS if not set)
NOTIFY_EMAIL=your-notify-address@gmail.com

# ── Calendly ───────────────────────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/derek-albrecht-keystn/30min
